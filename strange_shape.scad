// function to convert a list of points in a section to list of line segments

function seg(sec)=[for(i=[0:len(sec)-1])let(
 i_plus=i<len(sec)-1?i+1:0,
 p0=sec[i],
 p1=sec[i_plus],
 l=[p0,p1]
 )l];

 // function to convert a 2d section to 3d
